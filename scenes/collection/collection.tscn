[gd_scene load_steps=4 format=3 uid="uid://collection_scene"]

[ext_resource type="Script" path="res://scenes/collection/collection.gd" id="1_col"]
[ext_resource type="Script" path="res://scenes/ui/card_grid.gd" id="2_grid"]
[ext_resource type="Script" path="res://scenes/ui/card_filter_bar.gd" id="3_filter"]

[node name="Collection" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1_col")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.1, 0.12, 0.15, 1)

[node name="Layout" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 16.0
offset_top = 16.0
offset_right = -16.0
offset_bottom = -16.0
theme_override_constants/separation = 12

[node name="Header" type="HBoxContainer" parent="Layout"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="BackButton" type="Button" parent="Layout/Header"]
layout_mode = 2
custom_minimum_size = Vector2(120, 40)
text = "← Back"

[node name="Title" type="Label" parent="Layout/Header"]
layout_mode = 2
size_flags_horizontal = 3
text = "Collection"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 24

[node name="OwnedToggle" type="CheckBox" parent="Layout/Header"]
layout_mode = 2
button_pressed = true
text = "Owned only"

[node name="OwnedLabel" type="Label" parent="Layout/Header"]
layout_mode = 2
custom_minimum_size = Vector2(200, 40)
horizontal_alignment = 2

[node name="ResetButton" type="Button" parent="Layout/Header"]
layout_mode = 2
custom_minimum_size = Vector2(150, 40)
text = "Reset Collection"
tooltip_text = "Permanently delete every owned card. Coins and packs are kept."

[node name="ResetConfirm" type="ConfirmationDialog" parent="."]
title = "Reset Collection?"
initial_position = 2
dialog_text = "This permanently deletes every card you own.

Coins and unopened packs are not affected.

Are you sure?"
ok_button_text = "Reset"

[node name="FilterBar" type="HFlowContainer" parent="Layout"]
layout_mode = 2
script = ExtResource("3_filter")

[node name="CardGrid" type="VBoxContainer" parent="Layout"]
layout_mode = 2
size_flags_vertical = 3
script = ExtResource("2_grid")
