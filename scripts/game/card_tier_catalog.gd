static func tier_of(card_id: String) -> int:
	return TIERS.get(card_id, -1)


static func cards_in_tier(tier: int) -> Array[String]:
	var out: Array[String] = []
	for k: String in TIERS.keys():
		if TIERS[k] == tier:
			out.append(k)
	return out
